# Public HTTPS URL of the deployed SecurityOS frontend.
SECURITYOS_APP_URL=https://app.example.com

# Stripe LIVE credentials. Create one recurring $10/month Price and one
# recurring $100/year Price in the Stripe Dashboard.
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_MONTHLY_ID=price_replace_monthly
STRIPE_PRICE_YEARLY_ID=price_replace_yearly

# Hybrid Supabase control plane (accounts/sites/device registrations only).
# Never expose the service-role key to frontend code.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me
